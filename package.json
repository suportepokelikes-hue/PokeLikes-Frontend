{
  "name": "likes-uai-front",
  "version": "0.1.0",
  "private": true,
  "description": "Frontend web da plataforma Likes Uai",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "tsc -p tsconfig.tests.json && node --test .tmp-tests/tests/*.test.js",
