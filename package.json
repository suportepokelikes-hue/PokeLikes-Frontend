    "test:e2e:list": "playwright test --list"
  },
  "dependencies": {
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.5",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.0",
    "typescript": "^5.8.2"
  }
}
